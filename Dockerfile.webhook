FROM golang:1.24 AS builder
ARG TARGETOS
ARG TARGETARCH

WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download

COPY cmd/webhook/ cmd/webhook/
COPY api/ api/
COPY internal/webhook/ internal/webhook/
COPY pkg/ pkg/

RUN CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH} \
    go build -a -o nodemanager-webhook ./cmd/webhook/

FROM gcr.io/distroless/static:nonroot
WORKDIR /
COPY --from=builder /workspace/nodemanager-webhook .
USER 65532:65532

ENTRYPOINT ["/nodemanager-webhook"]
